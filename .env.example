# ════════════════════════════════════════════════════════════════════════════
#  DRX (SolTradBot) — конфигурация
# ════════════════════════════════════════════════════════════════════════════
#  Скопируй этот файл в `.env` (рядом, в корне проекта) и заполни значения.
#  Кавычки не нужны, но допустимы для значений с пробелами.
#  Строки с # — комментарии, игнорируются.
#  .env уже в .gitignore — секреты не попадут в репозиторий.
# ════════════════════════════════════════════════════════════════════════════

# ─── Режим торговли ─────────────────────────────────────────────────────────
# true = DEMO (paper-trading, виртуальный счёт $10 000) — РЕКОМЕНДУЕТСЯ для старта.
# false = REAL (реальные свопы через Jupiter). Переключается и в рантайме: UI/Telegram.
DEMO_MODE=true

# ─── Кошелёк Solana (нужен только для REAL) ─────────────────────────────────
# Seed-фраза (12/24 слова) кошелька, с которого пойдут свопы.
# ⚠️ НИКОМУ не показывай. Можно не задавать здесь, а ввести в настройках приложения.
SOLANA_WALLET_SEED=

# ─── Solana RPC ─────────────────────────────────────────────────────────────
# Публичный RPC работает, но для боевого режима лучше Helius/QuickNode.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── Telegram-бот (РЕКОМЕНДУЕТСЯ) ───────────────────────────────────────────
# Получить токен: в Telegram @BotFather → /newbot
# Узнать chat_id: в Telegram @userinfobot
# Если оставить пустым — бот будет работать без Telegram (только REST/UI).
TG_BOT_TOKEN=
TG_CHAT_ID=

# ─── REST API защита ────────────────────────────────────────────────────────
# Любая длинная случайная строка. Используется как Bearer-токен для curl/UI.
# По умолчанию `soltrad-secret` — НЕ ИСПОЛЬЗОВАТЬ В ПРОДЕ.
SOLTRAD_API_KEY=soltrad-secret

# ─── База данных ────────────────────────────────────────────────────────────
# Путь к SQLite-файлу. Один и тот же файл могут использовать server и desktop.
DB_PATH=soltradbot.db

# ─── HTTP-порт сервера ──────────────────────────────────────────────────────
PORT=8080
